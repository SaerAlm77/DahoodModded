end

local function createStroke(instance, color, thickness)
	local stroke = Instance.new("UIStroke")
	stroke.Color = color or colors.Stroke
	stroke.Thickness = thickness or 1
	stroke.Parent = instance
	return stroke
end

local function tweenButtonFlash(button, baseColor)
	local bright = baseColor:Lerp(Color3.new(1, 1, 1), 0.1)
	local down = TweenService:Create(button, TweenInfo.new(0.08), {
		BackgroundColor3 = bright
	})
	local up = TweenService:Create(button, TweenInfo.new(0.14), {
		BackgroundColor3 = baseColor
	})
	down:Play()
	down.Completed:Connect(function()
		up:Play()
	end)
end

local function setGuiStoredSpawn(gui, position)
	if position then
		gui:SetAttribute("SpawnX", position.X)
		gui:SetAttribute("SpawnY", position.Y)
		gui:SetAttribute("SpawnZ", position.Z)
	else
		gui:SetAttribute("SpawnX", nil)
		gui:SetAttribute("SpawnY", nil)
		gui:SetAttribute("SpawnZ", nil)
	end
end

local function updateSelectedWeaponsAttribute(gui)
	local names = {}
	for name, enabled in pairs(inventoryToolStates) do
		if enabled then
			table.insert(names, name)
		end
	end
	table.sort(names)
	gui:SetAttribute("SelectedWeapons", table.concat(names, "|"))
end

local function cleanupBillboard()
	if billboardSpinConnection then
		billboardSpinConnection:Disconnect()
		billboardSpinConnection = nil
	end

	if targetBillboard then
		targetBillboard:Destroy()
		targetBillboard = nil
	end
end

local function createLockBillboard(player)
	cleanupBillboard()

	local character = getCharacter(player)
	local root = character and character:FindFirstChild("HumanoidRootPart")
	if not root then
		return
	end

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "QuickLockMarker"
	billboard.Size = UDim2.new(0, 60, 0, 60)
	billboard.StudsOffset = Vector3.new(0, 4, 0)
	billboard.AlwaysOnTop = true
	billboard.Adornee = root
	billboard.Parent = root

	local image = Instance.new("ImageLabel")
	image.Name = "SpinImage"
	image.BackgroundTransparency = 1
	image.Size = UDim2.fromScale(1, 1)
	image.Image = "rbxassetid://13612969927"
	image.Parent = billboard

	targetBillboard = billboard

	local spinSpeed = 80
	billboardSpinConnection = RunService.RenderStepped:Connect(function(dt)
		if not image or not image.Parent then
			if billboardSpinConnection then
				billboardSpinConnection:Disconnect()
				billboardSpinConnection = nil
			end
			return
		end

		image.Rotation += spinSpeed * dt * 60
		spinSpeed = math.max(0, spinSpeed - (70 * dt))

		if spinSpeed <= 0.05 then
			image.Rotation = image.Rotation % 360
			if billboardSpinConnection then
				billboardSpinConnection:Disconnect()
				billboardSpinConnection = nil
			end
		end
	end)
end

local function unlockTarget()
	lockEnabled = false
	currentTarget = nil
	cleanupBillboard()
end

local function lockToTarget(player)
	if not isValidTarget(player) then
		return
	end

	currentTarget = player
	lockEnabled = true
	createLockBillboard(player)
end

local function getNearestPlayerToMouse()
	local mousePos = getMousePosition()
	local closestPlayer = nil
	local closestDistance = math.huge

	for _, player in ipairs(Players:GetPlayers()) do
		if isValidTarget(player) then
			local root = getRoot(player)
			if root then
				local screenPos, onScreen = Camera:WorldToViewportPoint(root.Position)
				local dist

				if onScreen then
					dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
				else
					dist = (root.Position - Camera.CFrame.Position).Magnitude + 10000
				end

				if dist < closestDistance then
					closestDistance = dist
					closestPlayer = player
				end
			end
		end
	end

	return closestPlayer
end

local function toggleLock()
	if lockEnabled then
		unlockTarget()
		return
	end

	local target = selectedPlayer
	if not isValidTarget(target) then
		target = getNearestPlayerToMouse()
	end

	if target then
		lockToTarget(target)
	end
end

local function getFlatCameraForward()
	local look = Camera.CFrame.LookVector
	local flat = Vector3.new(look.X, 0, look.Z)
	if flat.Magnitude <= 0.001 then
		return Vector3.zero
	end
	return flat.Unit
end

local function getMacroDirection()
	local humanoid = getHumanoid(LocalPlayer)
	if humanoid and humanoid.MoveDirection.Magnitude > 0.05 then
		return humanoid.MoveDirection.Unit
	end
	return getFlatCameraForward()
end

local function applyMacroVelocity()
	local root = getRoot(LocalPlayer)
	local humanoid = getHumanoid(LocalPlayer)

	if not root or not humanoid or humanoid.Health <= 0 then
		return
	end

	local direction = getMacroDirection()
	if direction.Magnitude <= 0.001 then
		return
	end

	local currentVelocity = root.AssemblyLinearVelocity
	local horizontalVelocity = direction * MACRO_SPEED
	root.AssemblyLinearVelocity = Vector3.new(horizontalVelocity.X, currentVelocity.Y, horizontalVelocity.Z)
end

local function styleInteractive(button, baseColor, hoverColor)
	hoverColor = hoverColor or colors.CardHover
	button.BackgroundColor3 = baseColor
	button.BorderSizePixel = 0
	button.AutoButtonColor = false
	createRound(button, 10)

	button.MouseEnter:Connect(function()
		button.BackgroundColor3 = hoverColor
	end)

	button.MouseLeave:Connect(function()
		button.BackgroundColor3 = baseColor
	end)

	button.MouseButton1Click:Connect(function()
		tweenButtonFlash(button, baseColor)
	end)
end

