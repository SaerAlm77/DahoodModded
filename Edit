local function registerToolVisual(tool)
	if not tool or not tool:IsA("Tool") then
		return
	end

	if tool.TextureId and tool.TextureId ~= "" then
		inventoryToolIcons[tool.Name] = tool.TextureId
	end
end

local function getAllToolsByName()
	local byName = {}
	local backpack = getBackpack()
	local character = getCharacter(LocalPlayer)

	local function addTool(tool)
		if tool and tool:IsA("Tool") then
			registerToolVisual(tool)
			byName[tool.Name] = byName[tool.Name] or {}
			table.insert(byName[tool.Name], tool)
		end
	end

	if backpack then
		for _, item in ipairs(backpack:GetChildren()) do
			addTool(item)
		end
	end

	if character then
		for _, item in ipairs(character:GetChildren()) do
			addTool(item)
		end
	end

	return byName
end

local function getUniqueToolNames()
	local names = {}
	local found = {}
	local byName = getAllToolsByName()

	for toolName in pairs(byName) do
		found[toolName] = true
	end

	for toolName in pairs(found) do
		table.insert(names, toolName)
	end

	table.sort(names, function(a, b)
		return string.lower(a) < string.lower(b)
	end)

	return names
end

local function queueOrganiseInventory()
	if organiseQueued then
		return
	end

	organiseQueued = true
	task.delay(0.12, function()
		organiseQueued = false

		local backpack = getBackpack()
		local character = getCharacter(LocalPlayer)
		local humanoid = getHumanoid(LocalPlayer)
		local storage = getToolStorage()

		if not backpack or not character or not humanoid or humanoid.Health <= 0 then
			return
		end

		for _, item in ipairs(character:GetChildren()) do
			if item:IsA("Tool") then
				registerToolVisual(item)
				item.Parent = backpack
			end
		end

		task.wait()

		if not inventoryAutoEnabled then
			for _, item in ipairs(storage:GetChildren()) do
				if item:IsA("Tool") then
					item.Parent = backpack
				end
			end
			return
		end

		local keepTools = {}
		local moveTools = {}

		for _, item in ipairs(backpack:GetChildren()) do
			if item:IsA("Tool") then
				registerToolVisual(item)

				if inventoryToolStates[item.Name] then
					table.insert(keepTools, item)
				else
					table.insert(moveTools, item)
				end
			end
		end

		for _, item in ipairs(storage:GetChildren()) do
			if item:IsA("Tool") then
				registerToolVisual(item)

				if inventoryToolStates[item.Name] then
					table.insert(keepTools, item)
				end
			end
		end

		table.sort(keepTools, function(a, b)
			return string.lower(a.Name) < string.lower(b.Name)
		end)

		table.sort(moveTools, function(a, b)
			return string.lower(a.Name) < string.lower(b.Name)
		end)

		for _, tool in ipairs(moveTools) do
			if tool.Parent == backpack then
				tool.Parent = storage
			end
		end

		for _, tool in ipairs(keepTools) do
			if tool.Parent ~= backpack then
				tool.Parent = backpack
			end
		end
	end)
end

