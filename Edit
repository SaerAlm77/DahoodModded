local function showPage(name)
	currentPage = name
	screenGui:SetAttribute("CurrentPage", name)

	quickPage.Visible = name == "Quick Lock"
	macroPage.Visible = name == "Auto Macro"
	inventoryPage.Visible = name == "Inventory"
	spawnPage.Visible = name == "Spawn"

	if name == "Quick Lock" then
		contentTitle.Text = "Quick Lock"
		contentDesc.Text = "Target selection and lock key"
	elseif name == "Auto Macro" then
		contentTitle.Text = "Auto Macro"
		contentDesc.Text = "Hold a key to push movement forward"
	elseif name == "Inventory" then
		contentTitle.Text = "Automatic Inventory Organiser"
		contentDesc.Text = "Choose what stays in the hotbar"
	elseif name == "Spawn" then
		contentTitle.Text = "Custom Spawn Location"
		contentDesc.Text = "Pick where you want to respawn"
	end

	setActiveNav(name)
end

