local function createOrUpdateSpawnMarker(position)
	if not spawnMarker then
		spawnMarker = Instance.new("Part")
		spawnMarker.Name = "LocalCustomSpawnMarker"
		spawnMarker.Shape = Enum.PartType.Ball
		spawnMarker.Material = Enum.Material.Neon
		spawnMarker.Color = Color3.fromRGB(110, 168, 255)
		spawnMarker.Transparency = 0.85
		spawnMarker.CanCollide = false
		spawnMarker.CanQuery = false
		spawnMarker.CanTouch = false
		spawnMarker.Anchored = true
		spawnMarker.Size = Vector3.new(3, 3, 3)
		spawnMarker.Parent = Workspace
	end

	spawnMarker.Position = position
end

local function removeSpawnMarker()
	if spawnMarker then
		spawnMarker:Destroy()
		spawnMarker = nil
	end
end

local function getMouseGroundPosition()
	local mousePos = UserInputService:GetMouseLocation()
	local ray = Camera:ViewportPointToRay(mousePos.X, mousePos.Y)

	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude

	local exclude = {spawnMarker}
	local character = getCharacter(LocalPlayer)
	if character then
		table.insert(exclude, character)
	end

	rayParams.FilterDescendantsInstances = exclude

	local result = Workspace:Raycast(ray.Origin, ray.Direction * 2000, rayParams)
	if result then
		local sizeY = spawnMarker and spawnMarker.Size.Y or 3
		return result.Position + Vector3.new(0, sizeY * 0.5, 0)
	end

	return nil
end

local function finishSpawnSelection(confirm)
	spawnSelecting = false

	if spawnSelectionConnection then
		spawnSelectionConnection:Disconnect()
		spawnSelectionConnection = nil
	end

	if spawnCancelConnection then
		spawnCancelConnection:Disconnect()
		spawnCancelConnection = nil
	end

	if spawnConfirmConnection then
		spawnConfirmConnection:Disconnect()
		spawnConfirmConnection = nil
	end

	mainFrame.Visible = true

	if not confirm and selectedSpawnPosition then
		createOrUpdateSpawnMarker(selectedSpawnPosition)
	elseif not confirm then
		removeSpawnMarker()
	end
end

local function beginSpawnSelection()
	if spawnSelecting then
		return
	end

	spawnSelecting = true
	mainFrame.Visible = false
	createOrUpdateSpawnMarker(selectedSpawnPosition or Vector3.new(0, 3, 0))

	spawnSelectionConnection = RunService.RenderStepped:Connect(function()
		local groundPosition = getMouseGroundPosition()
		if groundPosition then
			createOrUpdateSpawnMarker(groundPosition)
		end
	end)

	spawnConfirmConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed then
			return
		end

		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			local groundPosition = getMouseGroundPosition()
			if groundPosition then
				selectedSpawnPosition = groundPosition
				createOrUpdateSpawnMarker(selectedSpawnPosition)
				setGuiStoredSpawn(screenGui, selectedSpawnPosition)
				updateSpawnStatus()
				finishSpawnSelection(true)
			end
		end
	end)

	spawnCancelConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed then
			return
		end

		if input.KeyCode == Enum.KeyCode.Escape or input.UserInputType == Enum.UserInputType.MouseButton2 then
			finishSpawnSelection(false)
		end
	end)
end

local function applyCustomSpawn(character)
	if not selectedSpawnPosition then
		return
	end

	task.defer(function()
		local root = character:WaitForChild("HumanoidRootPart", 5)
		local humanoid = character:FindFirstChildOfClass("Humanoid")
		if not root or not humanoid or humanoid.Health <= 0 then
			return
		end

		task.wait(0.1)
		character:PivotTo(CFrame.new(selectedSpawnPosition + Vector3.new(0, 2.5, 0)))
	end)
end

