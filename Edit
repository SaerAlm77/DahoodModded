UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then
		return
	end

	if listeningForKey and input.UserInputType == Enum.UserInputType.Keyboard then
		if input.KeyCode ~= Enum.KeyCode.Unknown then
			LOCK_KEY = input.KeyCode
			keyButton.Text = LOCK_KEY.Name
			screenGui:SetAttribute("LockKey", LOCK_KEY.Name)
		end
		listeningForKey = false
		return
	end

	if listeningForMacroKey and input.UserInputType == Enum.UserInputType.Keyboard then
		if input.KeyCode ~= Enum.KeyCode.Unknown then
			MACRO_KEY = input.KeyCode
			macroKeyButton.Text = MACRO_KEY.Name
			screenGui:SetAttribute("MacroKey", MACRO_KEY.Name)
		end
		listeningForMacroKey = false
		return
	end

	if spawnSelecting then
		return
	end

	if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == LOCK_KEY then
		toggleLock()
	end

	if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == MACRO_KEY then
		macroHeld = true
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == MACRO_KEY then
		macroHeld = false
	end
end)

macroConnection = RunService.RenderStepped:Connect(function()
	if macroHeld then
		applyMacroVelocity()
	end
end)

RunService:BindToRenderStep("QuickLockOnCamera", Enum.RenderPriority.Camera.Value + 1, function()
	if not lockEnabled then
		return
	end

	if not isValidTarget(currentTarget) then
		unlockTarget()
		return
	end

	local targetRoot = getRoot(currentTarget)
	if not targetRoot then
		unlockTarget()
		return
	end

	local currentPos = Camera.CFrame.Position
	local lookTarget = targetRoot.Position + Vector3.new(0, 2, 0)
	Camera.CFrame = CFrame.lookAt(currentPos, lookTarget)
end)

Players.PlayerRemoving:Connect(function(player)
	if player == selectedPlayer then
		selectedPlayer = nil
		updateSelectedLabel()
	end

	if player == currentTarget then
		unlockTarget()
	end
end)

